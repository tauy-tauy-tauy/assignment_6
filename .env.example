# Copy this file to .env and replace placeholder values.
# Do not commit .env (it is listed in .gitignore).

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
# Comma-separated hostnames (required on Render). Local dev can omit (defaults to *).
# DJANGO_ALLOWED_HOSTS=your-app.onrender.com

# --- PostgreSQL (required) ---
# Local dev: Render Dashboard → your Postgres → Connections → External Database URL
# Render web service: use Internal Database URL, or link the database to auto-set DATABASE_URL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# --- Cloudinary (required for photo uploads) ---
# https://console.cloudinary.com/ → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
